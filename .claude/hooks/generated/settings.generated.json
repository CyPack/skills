{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/generated/events/pre-tool-use.sh",
            "async": false,
            "timeout": 30
          }
        ],
        "matcher": "Edit|Write|MultiEdit"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/generated/events/post-tool-use.sh",
            "async": true,
            "timeout": 180
          }
        ],
        "matcher": "Edit|Write|MultiEdit"
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/generated/events/notification.sh",
            "async": true,
            "timeout": 15
          }
        ],
        "matcher": ""
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/generated/events/stop.sh",
            "async": false,
            "timeout": 300
          }
        ]
      }
    ]
  }
}
